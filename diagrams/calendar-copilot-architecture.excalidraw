      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1. Read-only OAuth",
      "fontSize": 19,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Read-only OAuth",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "decision-1-body",
      "type": "text",
      "x": 88,
      "y": 1060,
      "width": 324,
      "height": 52.5,
      "angle": 0,
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1164,
      "version": 1,
      "versionNonce": 1165,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Signal: calendar writes and email sending increase trust, scope, and demo risk.\n\nDecision: use calendar.events.readonly and generate copyable drafts instead of mutating user data.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Signal: calendar writes and email sending increase trust, scope, and demo risk.\n\nDecision: use calendar.events.readonly and generate copyable drafts instead of mutating user data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
