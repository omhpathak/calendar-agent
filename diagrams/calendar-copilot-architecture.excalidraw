      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Signal: VPs need calendar intelligence, not just event lists.\n\nDecision: expose meeting load, recurring load, collaborators, focus availability, and delegation-style recommendations.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Signal: VPs need calendar intelligence, not just event lists.\n\nDecision: expose meeting load, recurring load, collaborators, focus availability, and delegation-style recommendations.",
