      "updated": 1,
      "link": null,
      "locked": false,
      "text": "2. Tool-like calendar math",
      "fontSize": 19,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Tool-like calendar math",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "decision-2-body",
      "type": "text",
      "x": 488,
      "y": 1060,
      "width": 324,
      "height": 52.5,
      "angle": 0,
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1170,
      "version": 1,
      "versionNonce": 1171,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Signal: users care if meeting hours and availability are correct.\n\nDecision: compute facts with deterministic functions, then let OpenAI handle language.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Signal: users care if meeting hours and availability are correct.\n\nDecision: compute facts with deterministic functions, then let OpenAI handle language.",
      "autoResize": true,
      "lineHeight": 1.25
    },
