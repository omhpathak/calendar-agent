      "updated": 1,
      "link": null,
      "locked": false,
      "text": "5. No database for MVP",
      "fontSize": 19,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5. No database for MVP",
