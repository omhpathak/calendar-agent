      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "4. Meeting vs busy block split",
      "fontSize": 19,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Meeting vs busy block split",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "decision-4-body",
      "type": "text",
      "x": 88,
      "y": 1260,
      "width": 324,
      "height": 52.5,
      "angle": 0,
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1182,
      "version": 1,
      "versionNonce": 1183,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Signal: leaders often block work shifts, focus time, workouts, or travel.\n\nDecision: busy blocks block availability but do not inflate meeting-load metrics.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Signal: leaders often block work shifts, focus time, workouts, or travel.\n\nDecision: busy blocks block availability but do not inflate meeting-load metrics.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "decision-5",
