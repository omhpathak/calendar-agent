      "versionNonce": 1189,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Signal: the required workflow can be computed from the current calendar fetch.\n\nDecision: keep state ephemeral; production would add preferences, sync, and history.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Signal: the required workflow can be computed from the current calendar fetch.\n\nDecision: keep state ephemeral; production would add preferences, sync, and history.",
      "autoResize": true,
      "lineHeight": 1.25
    },
